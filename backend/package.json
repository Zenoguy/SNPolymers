    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.2",
    "nodemailer": "^9.0.1",
    "supabase": "^2.107.0",
    "tar": "^7.5.16",
    "twilio": "^5.1.0",
    "uuid": "^14.0.0",
    "zod": "^4.4.3"
  },
