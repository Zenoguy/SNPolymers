    "test:security": "node tests/hardening/test_security_definer.js",
    "test:matrix": "node tests/hardening/test_estimate_amount_matrix.js",
    "test:failure": "node tests/hardening/test_failure_injection.js",
    "test:performance": "node tests/hardening/test_performance.js",
    "test:all": "bash tests/run_all_tests.sh",
