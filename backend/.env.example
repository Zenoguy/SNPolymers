# Port
PORT=5000
NODE_ENV=development

# Frontend Client URL (for CORS)
FRONTEND_URL=http://localhost:5173

# Supabase Credentials
SUPABASE_URL=your_supabase_project_url
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# JWT Credentials
JWT_SECRET=generate_a_secure_at_least_256_bit_secret_string
# Access token lifetime (e.g. 15m, 30m). Default: 15m
JWT_ACCESS_EXPIRY=15m
# Refresh token lifetime (e.g. 7d, 14d). Default: 7d
JWT_REFRESH_EXPIRY=7d

# Telegram Bot API Credentials
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# Nodemailer / Gmail SMTP Configuration
GMAIL_USER=your_gmail_sender@gmail.com
GMAIL_APP_PASSWORD=your_gmail_app_password
ADMIN_EMAIL=admin_notifications_receiver@domain.com

# Filter test data (e.g. TEST_% work orders) in production/non-test environments
IDBP_FILTER_TEST_DATA=true

# Set to true to disable background Telegram bot long-polling
DISABLE_TELEGRAM_POLLING=false
